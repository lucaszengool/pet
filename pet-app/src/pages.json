        "navigationBarBackgroundColor": "#FFF8E1"
      }
    },
    {
      "path": "pages/order/index",
      "style": {
        "navigationBarTitleText": "我的订单",
        "navigationBarBackgroundColor": "#FFF8E1"
      }
    },
    {
      "path": "pages/settings/index",
